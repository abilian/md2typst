# md2typst user config
# Applied to every document converted via `md2typst` or `md2pdf`.
# Fields here can be overridden by project-level `md2typst.toml`, by
# front matter in the document, or by CLI flags.

# Default document class (can be overridden with --class or front matter `class:`)
default_class = "report"

[style]
# Shared base settings (inherited by all classes unless overridden)
# IBM Plex Sans — professional, humanist, great for technical reports
font = ["IBM Plex Sans", "Noto Sans", "Arial"]
# Inter — modern, crisp, optimized for readability
# font = ["Inter", "Noto Sans", "Arial"]
# Avenir — geometric, elegant (macOS built-in)
# font = ["Avenir", "Helvetica Neue", "Arial"]
# Serif alternative
# font = ["Source Serif 4", "Noto Serif", "Georgia", "Times New Roman"]
font_size = "11pt"
paper = "a4"

# ──────────────────────────────────────────────────
# article: compact, no page breaks between sections,
# flat numbering, no TOC by default
# ──────────────────────────────────────────────────
[classes.article]
preamble = """
#set par(justify: true, leading: 0.85em, spacing: 1.2em)
#show table.cell: set par(justify: false)
#show heading: set par(justify: false, first-line-indent: 0pt)

// Section numbering: skip level 1 (title), number from level 2
#set heading(numbering: (..nums) => {
  let n = nums.pos()
  if n.len() <= 1 { return none }
  numbering("1.1.1.", ..n.slice(1))
})

// Heading sizes
#show heading.where(level: 1): set text(size: 1.6em, weight: 600)
#show heading.where(level: 2): set text(size: 1.3em, weight: 600)
#show heading.where(level: 3): set text(size: 1.15em, weight: 600)
#show heading.where(level: 4): set text(size: 1.05em, weight: 600)

// Heading spacing — moderate, no page breaks
#show heading.where(level: 1): set block(above: 2.0em, below: 1.0em)
#show heading.where(level: 2): set block(above: 1.6em, below: 0.8em)
#show heading.where(level: 3): set block(above: 1.2em, below: 0.6em)
#show heading.where(level: 4): set block(above: 1.0em, below: 0.5em)

// Lists
#set list(spacing: 0.8em, indent: 1.5em)
#set enum(spacing: 0.8em, indent: 1.5em)

// TOC: inline, no page break
#set outline(title: text(size: 0.72em, weight: 600, "Contents"))

// Title block: inline on first page (like LaTeX article)
#let doc-make-title() = {
  set align(center)
  set par(justify: false)
  block(spacing: 1.5em)[
    #if doc-title != none [#text(size: 1.6em, weight: 600, doc-title) #v(0.2em)]
    #if doc-subtitle != none [#text(size: 1.2em, fill: luma(80), doc-subtitle) #v(0.2em)]
    #{
      let parts = ()
      if doc-author != none { parts.push(doc-author) }
      if doc-authors != none { parts.push(doc-authors) }
      if doc-date != none { parts.push(doc-date) }
      if doc-version != none { parts.push("v" + str(doc-version)) }
      if parts.len() > 0 { text(size: 1em, parts.join(" · ")) }
    }
    #if doc-publisher != none [#v(0.2em) #text(style: "italic", doc-publisher)]
  ]
  v(1em)
}
"""

# ──────────────────────────────────────────────────
# report: numbered sections, page breaks before
# sections, generous spacing, TOC on its own page
# ──────────────────────────────────────────────────
[classes.report]
preamble = """
#set par(justify: true, leading: 0.85em, spacing: 1.2em)
#show table.cell: set par(justify: false)
#show heading: set par(justify: false, first-line-indent: 0pt)

// Number sections from level 2 (h1 = title, h2 = "1.", h3 = "1.1.", etc.)
#set heading(numbering: (..nums) => {
  let n = nums.pos()
  if n.len() <= 1 { return none }
  numbering("1.1.1.1.", ..n.slice(1))
})

// Heading sizes (semibold)
#show heading.where(level: 1): set text(size: 1.8em, weight: 600)
#show heading.where(level: 2): set text(size: 1.5em, weight: 600)
#show heading.where(level: 3): set text(size: 1.3em, weight: 600)
#show heading.where(level: 4): set text(size: 1.15em, weight: 600)
#show heading.where(level: 5): set text(size: 1.05em, weight: 600)

// Page break before each section (level 2)
#show heading.where(level: 2): it => { pagebreak(weak: true); it }

// Heading spacing — generous above, clear below
#show heading.where(level: 1): set block(above: 3.0em, below: 1.5em)
#show heading.where(level: 2): set block(above: 2.4em, below: 1.2em)
#show heading.where(level: 3): set block(above: 2.0em, below: 1.0em)
#show heading.where(level: 4): set block(above: 1.6em, below: 0.8em)

// Lists
#set list(spacing: 0.8em, indent: 2em)
#set enum(spacing: 0.8em, indent: 2em)

// TOC: page break before, style title, exclude level-1 headings
#show outline: it => { pagebreak(weak: true); it }
#set outline(title: text(size: 0.72em, weight: 600, "Table of Contents"))
#show heading.where(level: 1): set heading(outlined: false)

// Title block: centered with rule (separate from content)
#let doc-make-title() = {
  set align(center)
  set par(justify: false)
  block(spacing: 2em)[
    #if doc-title != none [#text(size: 2em, weight: 600, doc-title) #v(0.3em)]
    #if doc-subtitle != none [#text(size: 1.4em, fill: luma(80), doc-subtitle) #v(0.3em)]
    #if doc-author != none [#text(size: 1.1em, doc-author) #v(0.2em)]
    #if doc-authors != none [#text(size: 1.1em, doc-authors) #v(0.2em)]
    #{
      let parts = ()
      if doc-date != none { parts.push(doc-date) }
      if doc-version != none { parts.push("v" + str(doc-version)) }
      if parts.len() > 0 { text(size: 1em, fill: luma(100), parts.join(" · ")) }
    }
    #if doc-publisher != none [#v(0.3em) #text(size: 1em, style: "italic", doc-publisher)]
  ]
  line(length: 60%, stroke: 0.5pt + luma(180))
  v(1em)
}
"""

# ──────────────────────────────────────────────────
# book: like report but two-sided layout,
# asymmetric margins for binding, chapters start
# on odd (recto) pages
# ──────────────────────────────────────────────────
[classes.book]
margin = "auto"
preamble = """
#set par(justify: true, leading: 0.85em, spacing: 1.2em)
#show table.cell: set par(justify: false)
#show heading: set par(justify: false, first-line-indent: 0pt)

// Two-sided layout: asymmetric margins for binding
#set page(margin: (inside: 3cm, outside: 2cm, top: 2.5cm, bottom: 2.5cm))

// Number sections from level 2 (h1 = chapter title)
#set heading(numbering: (..nums) => {
  let n = nums.pos()
  if n.len() <= 1 { return none }
  numbering("1.1.1.1.", ..n.slice(1))
})

// Heading sizes
#show heading.where(level: 1): set text(size: 2.0em, weight: 600)
#show heading.where(level: 2): set text(size: 1.5em, weight: 600)
#show heading.where(level: 3): set text(size: 1.3em, weight: 600)
#show heading.where(level: 4): set text(size: 1.15em, weight: 600)
#show heading.where(level: 5): set text(size: 1.05em, weight: 600)

// Chapters (level 1) start on odd pages; sections on new pages
#show heading.where(level: 1): it => {
  pagebreak(to: "odd", weak: true)
  v(3em)
  it
  v(1.5em)
}
#show heading.where(level: 2): it => { pagebreak(weak: true); it }

// Heading spacing
#show heading.where(level: 2): set block(above: 2.4em, below: 1.2em)
#show heading.where(level: 3): set block(above: 2.0em, below: 1.0em)
#show heading.where(level: 4): set block(above: 1.6em, below: 0.8em)

// Lists
#set list(spacing: 0.8em, indent: 2em)
#set enum(spacing: 0.8em, indent: 2em)

// Headers: chapter title on even/odd pages (skip if no chapter yet)
#set page(header: context {
  let chapters = query(heading.where(level: 1).before(here()))
  if chapters.len() > 0 {
    let title = chapters.last().body
    if calc.odd(here().page()) {
      align(right, emph(title))
    } else {
      align(left, emph(title))
    }
  }
})

// TOC: starts on odd page, exclude level-1 from numbering
#show outline: it => { pagebreak(to: "odd", weak: true); it }
#set outline(title: text(size: 0.72em, weight: 600, "Table of Contents"))
#show heading.where(level: 1): set heading(outlined: false)

// Title page: full separate page (like LaTeX book)
#let doc-make-title() = {
  set page(numbering: none)
  set align(center + horizon)
  set par(justify: false)
  block[
    #if doc-title != none [#text(size: 2.4em, weight: 600, doc-title) #v(0.5em)]
    #if doc-subtitle != none [#text(size: 1.6em, weight: 400, fill: luma(80), doc-subtitle) #v(0.5em)]
    #line(length: 40%, stroke: 1pt + luma(150))
    #v(1em)
    #if doc-author != none [#text(size: 1.3em, doc-author) #v(0.3em)]
    #if doc-authors != none [#text(size: 1.3em, doc-authors) #v(0.3em)]
    #v(2em)
    #if doc-date != none [#text(size: 1.1em, fill: luma(100), doc-date)]
    #if doc-version != none [
      #h(1em)
      #text(size: 1.1em, fill: luma(100), "Version " + str(doc-version))
    ]
    #if doc-publisher != none [#v(1em) #text(size: 1.2em, style: "italic", doc-publisher)]
  ]
  pagebreak()
}
"""
